.gallery-container{min-height:100vh;background-color:#f5f5f5;padding:20rpx;box-sizing:border-box}.single-view .image-card{background-color:#fff;overflow:hidden;box-shadow:0 4rpx 20rpx rgba(0,0,0,.05);margin-bottom:30rpx}.single-view .large-image{width:100%;display:block}.single-view .image-info{padding:30rpx}.single-view .image-title{font-size:36rpx;font-weight:700;color:#333;margin-bottom:20rpx}.single-view .image-desc{font-size:28rpx;color:#666;line-height:1.6;white-space:pre-wrap}.single-view .image-desc-placeholder{font-size:28rpx;color:#999;line-height:1.6;font-style:italic}
