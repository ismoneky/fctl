
.container.data-v-fe20bf6b {
		min-height: 100vh;
		background-color: #f5f5f5;
		padding-bottom: 40rpx;
		box-sizing: border-box;
}
.form-container.data-v-fe20bf6b {
		padding: 20rpx 30rpx 0;
		box-sizing: border-box;
}

	/* 订单状态栏 */
.status-bar.data-v-fe20bf6b {
		display: flex;
		align-items: center;
		border-radius: 20rpx;
		padding: 28rpx 30rpx;
		margin-bottom: 20rpx;
		box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}
.status-bar-pending.data-v-fe20bf6b   { background: linear-gradient(135deg, #ff9800, #f57c00);
}
.status-bar-confirmed.data-v-fe20bf6b { background: linear-gradient(135deg, #667eea, #764ba2);
}
.status-bar-completed.data-v-fe20bf6b { background: linear-gradient(135deg, #43e97b, #38f9d7);
}
.status-bar-cancelled.data-v-fe20bf6b { background: linear-gradient(135deg, #bbb, #999);
}
.status-bar-refunded.data-v-fe20bf6b  { background: linear-gradient(135deg, #f5515f, #f7971e);
}
.status-bar-icon.data-v-fe20bf6b {
		font-size: 56rpx;
		margin-right: 24rpx;
		flex-shrink: 0;
}
.status-bar-info.data-v-fe20bf6b {
		display: flex;
		flex-direction: column;
}
.status-bar-label.data-v-fe20bf6b {
		font-size: 34rpx;
		font-weight: bold;
		color: #fff;
		margin-bottom: 6rpx;
}
.status-bar-desc.data-v-fe20bf6b {
		font-size: 24rpx;
		color: rgba(255, 255, 255, 0.85);
		line-height: 1.5;
}

	/* 倒计时卡片 */
.countdown-card.data-v-fe20bf6b {
		background: #fff;
		border-radius: 20rpx;
		padding: 30rpx;
		margin-bottom: 20rpx;
		box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
		display: flex;
		flex-direction: column;
		align-items: center;
}
.countdown-tip.data-v-fe20bf6b {
		font-size: 24rpx;
		color: #999;
		margin-bottom: 20rpx;
		text-align: center;
}
.countdown-time.data-v-fe20bf6b {
		display: flex;
		align-items: center;
}
.time-block.data-v-fe20bf6b {
		display: flex;
		align-items: baseline;
		background: #fff8f0;
		border-radius: 12rpx;
		padding: 10rpx 24rpx;
}
.time-num.data-v-fe20bf6b {
		font-size: 64rpx;
		font-weight: bold;
		color: #f57c00;
		line-height: 1;
		font-variant-numeric: tabular-nums;
}
.time-unit.data-v-fe20bf6b {
		font-size: 24rpx;
		color: #f57c00;
		margin-left: 6rpx;
}
.time-sep.data-v-fe20bf6b {
		font-size: 48rpx;
		font-weight: bold;
		color: #f57c00;
		margin: 0 16rpx;
		line-height: 1;
}

	/* 表单区块 */
.form-section.data-v-fe20bf6b {
		background: #fff;
		border-radius: 20rpx;
		padding: 30rpx;
		margin-bottom: 20rpx;
		box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
		box-sizing: border-box;
		width: 100%;
		overflow: hidden;
}
.section-title.data-v-fe20bf6b {
		display: flex;
		align-items: center;
		margin-bottom: 30rpx;
		padding-bottom: 20rpx;
		border-bottom: 2rpx solid #f0f0f0;
}
.title-icon.data-v-fe20bf6b {
		font-size: 40rpx;
		margin-right: 15rpx;
}
.title-text.data-v-fe20bf6b {
		font-size: 32rpx;
		font-weight: bold;
		color: #333;
}

	/* 表单项 */
.form-item.data-v-fe20bf6b {
		margin-bottom: 30rpx;
		position: relative;
		width: 100%;
		box-sizing: border-box;
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: flex-start;
}
.form-item.data-v-fe20bf6b:last-child {
		margin-bottom: 0;
}
.label.data-v-fe20bf6b {
		display: block;
		font-size: 28rpx;
		color: #666;
		margin-bottom: 0;
		font-weight: 400;
		width: 180rpx;
		flex-shrink: 0;
}
.detail-value.data-v-fe20bf6b {
		font-size: 28rpx;
		color: #333;
		font-weight: 500;
		line-height: 1.5;
		word-break: break-all;
		text-align: left;
		flex: 1;
}

	/* 二维码区域 */
.qr-section.data-v-fe20bf6b {
		margin-bottom: 20rpx;
}
.qr-card.data-v-fe20bf6b {
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		border-radius: 20rpx;
		padding: 40rpx 30rpx 36rpx;
		display: flex;
		flex-direction: column;
		align-items: center;
		box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.3);
}
.qr-card-title.data-v-fe20bf6b {
		font-size: 34rpx;
		font-weight: bold;
		color: #fff;
		margin-bottom: 10rpx;
}
.qr-card-subtitle.data-v-fe20bf6b {
		font-size: 24rpx;
		color: rgba(255, 255, 255, 0.75);
		margin-bottom: 36rpx;
}
.qr-code-wrap.data-v-fe20bf6b {
		background: #fff;
		border-radius: 20rpx;
		padding: 20rpx;
		box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
}
.qr-code.data-v-fe20bf6b {
		width: 360rpx;
		height: 360rpx;
		display: block;
}
.qr-booking-id.data-v-fe20bf6b {
		margin-top: 28rpx;
		font-size: 22rpx;
		color: rgba(255, 255, 255, 0.6);
		letter-spacing: 1px;
}

	/* 操作按钮栏 */
.action-bar.data-v-fe20bf6b {
		padding: 20rpx 0 10rpx;
}
.pay-btn.data-v-fe20bf6b {
		height: 90rpx;
		line-height: 90rpx;
		text-align: center;
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		color: #fff;
		font-size: 34rpx;
		font-weight: bold;
		border-radius: 45rpx;
		box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
}
.refund-btn.data-v-fe20bf6b {
		height: 90rpx;
		line-height: 90rpx;
		text-align: center;
		background: #fff;
		color: #f5515f;
		font-size: 32rpx;
		font-weight: bold;
		border-radius: 45rpx;
		border: 2rpx solid #f5515f;
}
